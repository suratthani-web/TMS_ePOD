# Supabase Configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"

# DTC GPS Integration
DTC_USER="ddpakchong"
DTC_PASS="DDGPS"
DTC_API_URL="https://gps.dtc.co.th/backendv2/api/v1/auth/login"
DTC_REALTIME_URL="https://gps.dtc.co.th/backendv2/api/v1/ultimate/realtime"
DTC_TOKEN=""

# Debug Mode
TMS_DEBUG="0"

# Timezone — Vercel/Node runs in UTC. All date/time logic is handled explicitly
# via src/lib/utils/date-th.ts (Asia/Bangkok), so no runtime TZ is required.
# NOTE: `TZ` is a RESERVED name on Vercel and cannot be set in its dashboard —
# this line is only for local dev parity, not production.
TZ="Asia/Bangkok"

# LINE LIFF Configuration
NEXT_PUBLIC_APP_URL="https://your-production-url.vercel.app"
NEXT_PUBLIC_LIFF_SIGNATURE_ID="your-liff-app-id-here"
